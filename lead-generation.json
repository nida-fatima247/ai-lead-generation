    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  let text = item.json.text || item.json.output || Object.values(item.json)[0];\n\n  text = text\n    .replace(/```json/g, \"\")\n    .replace(/```/g, \"\")\n    .trim();\n\n  try {\n    return {\n      json: JSON.parse(text)\n    };\n  } catch (e) {\n    return {\n      json: {\n        parse_failed: true,\n        error: e.message,\n        raw_output: text\n      }\n    };\n  }\n});"
      },
